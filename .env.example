# ============================================================
# Sinnergia Platform — variables de entorno (plantilla)
# Copiá este archivo a `.env.local` y completá los valores.
# `.env.local` está ignorado por git — nunca subas credenciales.
# ============================================================

# --- Base de datos (Supabase / Neon) -----------------------
# Supabase → Project Settings → Database → Connection string → "URI".
# IMPORTANTE: usá el pooler (puerto 6543) para la app, y agregá ?pgbouncer=true.
# Reemplazá [PASSWORD] por la contraseña de la base.
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-xx.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Conexión directa (puerto 5432) — la usa Prisma para migraciones.
DIRECT_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-xx.pooler.supabase.com:5432/postgres"

# --- Autenticación (Auth.js) -------------------------------
# Generá el secret con:  openssl rand -base64 32
AUTH_SECRET=""
# URL pública de la app (en local dejá esta)
NEXTAUTH_URL="http://localhost:3000"

# --- Usuario admin inicial (para el seed) ------------------
ADMIN_EMAIL="admin@sinnergia.studio"
ADMIN_PASSWORD="cambiala-por-una-segura"
# Contraseña de los usuarios demo (freelancer/empresa) que crea el seed
DEMO_PASSWORD="demo1234"

# --- App ----------------------------------------------------
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# --- Email transaccional (Resend) --------------------------
RESEND_API_KEY=""
# Remitente. En prueba: "onboarding@resend.dev" (solo entrega al dueño de la cuenta).
# Con dominio verificado: "Sinnergia Studio <hola@sinnergia.studio>".
EMAIL_FROM="Sinnergia Studio <onboarding@resend.dev>"

# --- Almacenamiento de archivos (Vercel Blob) ---------------
# Vercel dashboard → tu proyecto → Storage → Create Database → Blob.
# Al conectarlo al proyecto, Vercel agrega esta variable solo en producción;
# copiá el mismo valor acá para poder subir fotos en local.
BLOB_READ_WRITE_TOKEN=""
