// Esquema de datos de Sinnergia Platform.
// Deriva de src/lib/types.ts y src/lib/schema-notes.md.
// Base: PostgreSQL (Supabase/Neon). ORM: Prisma.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// --- Enumeraciones estables (controladas por código) ------------------------

enum UserRole {
  freelancer
  empresa
  admin
}

enum EstadoProfesional {
  pendiente
  aprobado
  rechazado
  oculto
}

enum EstadoLead {
  nuevo
  en_conversacion
  propuesta_enviada
  cerrado_ganado
  cerrado_perdido
}

enum EstadoMatch {
  solicitado
  en_gestion
  cerrado
  descartado
}

enum ContactStatus {
  pending
  accepted
  rejected
  cancelled
  archived
}

enum EstadoReporte {
  pendiente
  revisado
  descartado
}

enum FeedbackStatus {
  draft
  published
}

// --- Usuarios (auth) --------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  // Opcional: las cuentas que entran SOLO con Google no tienen contraseña.
  // El login por contraseña rechaza cuentas sin passwordHash.
  passwordHash  String?
  nombre        String
  role          UserRole
  emailVerified DateTime?
  // Login con Google: `googleId` es el `sub` de Google (identifica la cuenta),
  // `image` es la foto de perfil. Nullable: no todas las cuentas usan Google.
  googleId      String?   @unique
  image         String?
  createdAt     DateTime  @default(now())

  // Ciclo de vida de la cuenta.
  // - lastLoginAt: se refresca en cada login. La "inactividad" (>30d sin
  //   loguear) se DERIVA de este campo en las queries; no hay estado que flipear.
  // - disabledAt: deshabilitación MANUAL (el usuario se ocultó a propósito).
  //   No se limpia al loguear; requiere reactivación explícita.
  // - deletedAt: soft-delete + anonimización. Cuenta fuera del sistema.
  // - inactivityWarnedAt: evita reenviar el aviso de inactividad; se limpia al loguear.
  lastLoginAt        DateTime  @default(now())
  disabledAt         DateTime?
  // true → la deshabilitación la hizo un admin (suspensión). El usuario NO puede
  // reactivarse solo; solo un admin la levanta. false → baja propia (self-service).
  disabledByAdmin    Boolean   @default(false)
  deletedAt          DateTime?
  inactivityWarnedAt DateTime?

  // Vínculo con la entidad de dominio según el rol
  professional   Professional? @relation(fields: [professionalId], references: [id])
  professionalId String?       @unique
  company        Company?      @relation(fields: [companyId], references: [id])
  companyId      String?       @unique

  verificationTokens EmailVerificationToken[]
  resetTokens         PasswordResetToken[]
}

// --- Verificación de email y recuperación de contraseña --------------------

model EmailVerificationToken {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

// --- Rate limiting (sin infra externa, respaldado en la DB) ----------------

model RateLimitHit {
  id        String   @id @default(cuid())
  key       String
  createdAt DateTime @default(now())

  @@index([key, createdAt])
}

// --- Dominio ----------------------------------------------------------------

model Professional {
  id             String            @id @default(cuid())
  nombre         String
  email          String
  whatsapp       String?
  linkedin       String?
  instagram      String?
  facebook       String?
  portfolioUrl   String?
  fotoUrl        String?
  titular        String
  descripcion    String
  // Valores de catálogo (flexibles, editables): se validan en la app
  roles          String[]
  rubros         String[]
  skills         String[] @default([])
  tecnologias    String[] @default([])
  idiomas        String[] @default([])
  experiencia    String
  honorarios     String
  modalidad      String
  disponibilidad String
  ubicacion      String?
  // Portfolio: descripción general + hasta 3 imágenes de galería.
  // Los proyectos individuales viven en PortfolioItem.
  portfolioDescripcion String?
  portfolioImagenes    String[] @default([])
  // Moderación
  estado         EstadoProfesional @default(pendiente)
  destacado      Boolean           @default(false)
  // Momento de la PRIMera aprobación (se setea al pasar a "aprobado"). Sirve para
  // medir el tiempo de moderación; `updatedAt` no sirve porque cambia con cualquier edición.
  aprobadoAt     DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  user       User?
  candidatos MatchCandidate[]
  portfolio  PortfolioItem[]
  contacts   Contact[]
  reports    Report[]

  @@index([estado])
}

// --- Reportes de contenido (moderación reactiva) ----------------------------
// Cualquier usuario logueado puede reportar un perfil que le parezca inapropiado
// o peligroso. El admin los revisa desde el backoffice. professionalId es
// nullable + onDelete: SetNull para conservar el reporte si el perfil se borra.
model Report {
  id             String        @id @default(cuid())
  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)
  professionalId String?
  motivo         String
  detalle        String?
  reporterUserId String?
  reporterIp     String?
  estado         EstadoReporte @default(pendiente)
  createdAt      DateTime      @default(now())

  @@index([estado])
  @@index([professionalId])
}

model PortfolioItem {
  id             String       @id @default(cuid())
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String
  titulo         String
  descripcion    String
  imagenUrl      String?
  enlace         String?
  orden          Int          @default(0)
  createdAt      DateTime     @default(now())

  @@index([professionalId])
}

model Company {
  id        String   @id @default(cuid())
  nombre    String
  contacto  String
  email     String
  telefono  String?
  rubro     String
  tamano    String?
  sitioWeb  String?
  origen    String?
  createdAt DateTime @default(now())
  // Perfil (visible al freelancer en el futuro cuando la empresa lo contacte)
  descripcion String?
  logoUrl     String?
  linkedin    String?
  instagram   String?
  ubicacion   String?

  user      User?
  diagnoses Diagnosis[]
  matches   MatchRequest[]
  contacts  Contact[]
  meetings  Meeting[]
  feedbacks Feedback[]
}

model Contact {
  id                     String        @id @default(cuid())
  company                Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId              String
  professional           Professional  @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId         String
  status                 ContactStatus @default(pending)
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  readAt                 DateTime?
  lastNotificationSentAt DateTime?

  @@index([professionalId, status])
  @@index([companyId])
}

model Diagnosis {
  id                String     @id @default(cuid())
  company           Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId         String
  rubro             String
  facturacion       String?
  objetivos         String
  presupuesto       String
  equipoActual      String?
  problemaPrincipal String
  respuestasExtra   Json?
  estadoLead        EstadoLead @default(nuevo)
  notas             String?
  createdAt         DateTime   @default(now())

  matches MatchRequest[]

  @@index([estadoLead])
}

model MatchRequest {
  id          String      @id @default(cuid())
  company     Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId   String
  diagnosis   Diagnosis?  @relation(fields: [diagnosisId], references: [id])
  diagnosisId String?
  contexto    String
  estado      EstadoMatch @default(solicitado)
  resultado   String?
  createdAt   DateTime    @default(now())

  candidatos MatchCandidate[]

  @@index([estado])
}

// --- Devoluciones / Feedback a empresas -------------------------------------
// El estudio (admin) genera una devolución oficial para una empresa tras la
// sesión de consulta. `descriptionMd`/`fortalezasMd`/`mejorasMd` son Markdown.
// Los adjuntos se guardan en Vercel Blob; se descargan por una ruta autenticada
// (no se expone la URL del blob directamente).
model Feedback {
  id            String         @id @default(cuid())
  company       Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId     String
  diagnosisId   String? // diagnóstico que responde (opcional)
  createdById   String? // admin que la creó
  title         String
  descriptionMd String
  score         Int? // puntaje general 1-5 (opcional)
  fortalezasMd  String?
  mejorasMd     String?
  categoria     String? // Legal | Técnica | Comercial | UX | Documentación | General
  status        FeedbackStatus @default(draft)
  publishedAt   DateTime?
  readAt        DateTime? // cuándo la empresa la abrió por primera vez
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  attachments FeedbackAttachment[]

  @@index([companyId])
  @@index([status])
}

model FeedbackAttachment {
  id         String   @id @default(cuid())
  feedback   Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)
  feedbackId String
  fileName   String
  url        String // URL de Vercel Blob (no se expone directo al cliente)
  mimeType   String
  size       Int
  createdAt  DateTime @default(now())

  @@index([feedbackId])
}

// --- Google Calendar (calendario compartido del estudio) --------------------
// Singleton: una sola cuenta de Google del estudio conectada. `refreshToken`
// va CIFRADO (AES-256-GCM, ver src/lib/crypto.ts).
model GoogleCalendarConnection {
  id            String   @id @default(cuid())
  email         String
  refreshToken  String
  calendarId    String   @default("primary")
  connectedById String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Sesión de consulta agendada (evento de Google Calendar con Meet).
model Meeting {
  id            String   @id @default(cuid())
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  companyId     String
  diagnosisId   String?
  scheduledById String? // admin que la agendó
  titulo        String
  startsAt      DateTime
  endsAt        DateTime
  googleEventId String?
  meetUrl       String?
  htmlLink      String?
  estado        String   @default("agendada") // agendada | cancelada
  createdAt     DateTime @default(now())

  @@index([startsAt])
  @@index([companyId])
}

model MatchCandidate {
  id             String       @id @default(cuid())
  matchRequest   MatchRequest @relation(fields: [matchRequestId], references: [id], onDelete: Cascade)
  matchRequestId String
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  professionalId String
  puntaje        Int          @default(0)
  seleccionado   Boolean      @default(false)

  @@unique([matchRequestId, professionalId])
}
